# Notion（旧dive-logの読み取り用）
NOTION_TOKEN=secret_xxx

# Supabase（Project Settings → API）
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...   # service_role キー。絶対にコミットしない

# 移行先ユーザーのUUID（Supabaseダッシュボード → Authentication → Users で確認）
TARGET_USER_ID=00000000-0000-0000-0000-000000000000

# 旧dive-logプロジェクトのパス（notion_ids.json / docs/photos / data/depth_profiles を読む）
OLD_PROJECT_DIR=/Users/harutakizawa/Desktop/claude code/dive-log
